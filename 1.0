<script>
const secs=[...document.querySelectorAll('section')];
const nd=document.getElementById('navDots');
secs.forEach((_,i)=>{
  const d=document.createElement('div');
  d.className='nav-dot'+(i===0?' active':'');
  d.onclick=()=>secs[i].scrollIntoView({behavior:'smooth'});
  nd.appendChild(d);
});
const so=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting){const i=secs.indexOf(x.target);document.querySelectorAll('.nav-dot').forEach((d,j)=>d.classList.toggle('active',j===i))}})},{threshold:.4});
secs.forEach(s=>so.observe(s));
const ro=new IntersectionObserver(e=>{e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('on')})},{threshold:.12});
document.querySelectorAll('.rv').forEach(el=>ro.observe(el));
</script>
