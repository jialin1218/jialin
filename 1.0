<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Jialin Portfolio · 海外内容增长作品集</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Noto+Sans+SC:wght@400;500;700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --purple:#7C6EF5;--purple-l:#B5ADFA;--purple-bg:#F0EEFF;
  --yellow:#F5DC4A;--yellow-l:#FFE58A;--yellow-bg:#FFFDE7;
  --green:#6DD5A0;--green-l:#B2EDD0;--green-bg:#EDFAF3;
  --pink:#FF8FAB;--pink-l:#FFCCD8;--pink-bg:#FFF0F4;
  --blue:#5BC3F5;--blue-l:#B3E4FB;--blue-bg:#F0FAFF;
  --bg:#FAFAFA;--surface:#FFFFFF;
  --text-h:#1A1040;--text-b:#3D3560;--text-s:#7B72A8;
  --border:rgba(124,110,245,0.15);
  --r:18px;--rs:10px;
  --sh:0 4px 24px rgba(124,110,245,0.10);
  --shh:0 8px 36px rgba(124,110,245,0.18);
  --max:1160px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);font-family:'Nunito','Noto Sans SC',sans-serif;color:var(--text-b);overflow-x:hidden}

/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;justify-content:space-between;align-items:center;padding:13px 48px;background:rgba(255,255,255,0.9);backdrop-filter:blur(16px);border-bottom:2px solid var(--purple-bg);box-shadow:0 2px 20px rgba(124,110,245,0.08)}
.nav-logo{font-weight:900;font-size:17px;color:var(--purple);letter-spacing:2px;text-transform:uppercase}
.nav-dots{display:flex;gap:8px;align-items:center}
.nav-dot{width:9px;height:9px;border-radius:50%;background:var(--purple-bg);border:2px solid var(--purple-l);cursor:pointer;transition:all .3s}
.nav-dot.active{background:var(--purple);border-color:var(--purple);transform:scale(1.4);box-shadow:0 0 0 3px rgba(124,110,245,0.2)}

/* SECTION */
section{width:100%;padding:68px 48px 56px;display:flex;justify-content:center;position:relative;overflow:hidden}
.inner{width:100%;max-width:var(--max);position:relative;z-index:2}

/* WAVE */
.wsep{width:100%;overflow:hidden;line-height:0;margin:-1px 0}
.wsep svg{display:block;width:100%}

/* PILLS & TAGS */
.pill{display:inline-flex;align-items:center;gap:6px;background:var(--purple-bg);color:var(--purple);font-size:11px;font-weight:800;letter-spacing:2px;text-transform:uppercase;border-radius:100px;padding:5px 14px;border:1.5px solid var(--purple-l);margin-bottom:14px}

/* REVEAL */
.rv{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
.rv.on{opacity:1;transform:none}
.rv:nth-child(2){transition-delay:.1s}.rv:nth-child(3){transition-delay:.2s}.rv:nth-child(4){transition-delay:.3s}.rv:nth-child(5){transition-delay:.4s}

/* ── S1 COVER ── */
#s1{background:linear-gradient(135deg,#F0EEFF 0%,#FFF0FA 45%,#F0FAFF 100%);min-height:100vh;align-items:center;padding-top:80px}
.blob{position:absolute;border-radius:50%;filter:blur(55px);opacity:.4;pointer-events:none}
.b1{width:480px;height:480px;background:var(--purple-l);top:-100px;right:-60px}
.b2{width:380px;height:380px;background:var(--pink-l);bottom:-60px;left:-40px}
.b3{width:280px;height:280px;background:var(--yellow-l);top:40%;left:38%}
.s1-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,0.9);border:2px solid var(--purple-l);border-radius:100px;padding:7px 20px;font-size:12px;font-weight:800;color:var(--purple);letter-spacing:2px;text-transform:uppercase;margin-bottom:22px;box-shadow:0 2px 12px rgba(124,110,245,0.12)}
.s1-title{font-weight:900;font-size:clamp(68px,10vw,132px);line-height:0.93;color:var(--text-h);letter-spacing:-3px}
.s1-title span{color:var(--purple)}
.s1-sub{font-family:'Noto Sans SC',sans-serif;font-weight:700;font-size:clamp(15px,2vw,22px);color:var(--text-s);letter-spacing:4px;margin-top:20px}
.s1-dots{display:flex;justify-content:center;gap:10px;margin-top:28px}
.s1-dot{width:11px;height:11px;border-radius:50%}

/* ── S2 ABOUT ── */
#s2{background:var(--surface)}
.s2-grid{display:grid;grid-template-columns:250px 1fr;gap:64px;align-items:center}
.photo-card{width:230px;height:288px;background:linear-gradient(145deg,var(--purple-bg),var(--pink-bg));border-radius:24px;border:2.5px solid var(--purple-l);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;box-shadow:var(--sh);overflow:hidden;position:relative}
.photo-card img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:22px}
.photo-icon{font-size:48px;opacity:.3}
.photo-lbl{font-size:11px;color:var(--text-s);letter-spacing:2px;font-weight:700}
.photo-wrap{position:relative;width:fit-content}
.deco{position:absolute;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 4px 14px rgba(245,220,74,.35)}
.d1{width:44px;height:44px;background:var(--yellow);top:-14px;right:-14px}
.d2{width:32px;height:32px;background:var(--pink);bottom:-10px;left:-10px;font-size:14px}
.s2-name{font-weight:900;font-size:56px;line-height:1;color:var(--text-h);letter-spacing:-2px;margin-bottom:6px}
.s2-subtitle{font-size:13px;font-weight:800;color:var(--purple);letter-spacing:2px;margin-bottom:30px;text-transform:uppercase}
.s2-tags{display:flex;flex-direction:column;gap:12px}
.s2-tag{display:flex;align-items:center;gap:14px;font-family:'Noto Sans SC',sans-serif;font-size:16px;font-weight:700;color:var(--text-b)}
.chk{width:30px;height:30px;border-radius:8px;background:var(--purple);display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;flex-shrink:0;box-shadow:0 3px 10px rgba(124,110,245,.3)}

/* ── S3 CONTENTS ── */
#s3{background:var(--purple-bg)}
.s3-head{text-align:center;margin-bottom:50px}
.s3-main{font-weight:900;font-size:46px;color:var(--text-h);letter-spacing:-1px}
.roadmap{display:flex;align-items:flex-start;justify-content:center}
.rm{display:flex;flex-direction:column;align-items:center;flex:1;max-width:290px;cursor:default}
.rm-circle{width:108px;height:108px;border-radius:50%;background:var(--surface);border:3px solid var(--purple-l);display:flex;align-items:center;justify-content:center;font-size:36px;box-shadow:var(--sh);transition:all .3s}
.rm:hover .rm-circle{background:var(--purple);border-color:var(--purple);box-shadow:var(--shh);transform:translateY(-5px) scale(1.05)}
.rm-conn{flex:0 0 56px;height:3px;margin-top:54px;background:linear-gradient(90deg,var(--purple-l),var(--pink-l));border-radius:10px;position:relative}
.rm-conn::after{content:'›';position:absolute;right:-10px;top:-12px;font-size:22px;color:var(--purple);font-weight:900}
.rm-num{font-family:'Space Mono',monospace;font-size:11px;color:var(--purple-l);letter-spacing:3px;margin-bottom:12px;font-weight:700}
.rm-lbl{margin-top:16px;font-family:'Noto Sans SC',sans-serif;font-size:16px;font-weight:900;color:var(--text-h);text-align:center;line-height:1.5}
.rm-en{font-size:11px;color:var(--text-s);text-align:center;margin-top:4px;font-weight:600}

/* ── FLAG PAGES ── */
.flag-page{width:100%;padding:68px 48px 56px;display:flex;justify-content:center;position:relative;overflow:hidden}
.flag-bg{position:absolute;inset:0;background-size:cover;background-position:center;filter:blur(22px);transform:scale(1.1);opacity:.16}
#s4{background:linear-gradient(150deg,#EEF2FF 0%,#FFF9E8 55%,#FFEEEE 100%)}
#s4 .flag-bg{background:linear-gradient(90deg,#002B7F 33.33%,#FCD116 33.33% 66.66%,#CE1126 66.66%)}
#s5{background:linear-gradient(150deg,#E8F4FF 0%,#F3F0FF 100%)}
#s5 .flag-bg{background:repeating-linear-gradient(180deg,#B22234 0 36px,#fff 36px 72px)}
.flag-head{margin-bottom:32px}
.flag-title{font-weight:900;font-size:clamp(26px,3.5vw,42px);color:var(--text-h);line-height:1;margin-top:8px}
.flag-sub{font-family:'Noto Sans SC',sans-serif;font-size:17px;font-weight:700;color:var(--purple);margin-top:6px}

/* IAI */
.iai-cols{display:grid;grid-template-columns:148px 1fr 1fr 1fr;gap:0;margin-bottom:5px}
.iai-ch{text-align:center;padding:8px 10px;font-family:'Space Mono',monospace;font-size:10px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;border-radius:10px 10px 0 0}
.iai-ch.ins{background:#EEF6FF;color:#2A7FBF;border:2px solid #B3DCFA;border-bottom:none}
.iai-ch.act{background:#FFF9E8;color:#C49A00;border:2px solid var(--yellow-l);border-bottom:none}
.iai-ch.imp{background:var(--green-bg);color:#1A8C58;border:2px solid var(--green-l);border-bottom:none}
.prow{display:grid;grid-template-columns:148px 1fr 1fr 1fr;border-radius:var(--r);overflow:visible;margin-bottom:9px;box-shadow:0 2px 14px rgba(0,0,0,.05);background:var(--surface);border:1.5px solid rgba(124,110,245,.09)}
.pname{background:linear-gradient(160deg,var(--purple-bg),#fff);border-right:2px dashed var(--purple-l);display:flex;align-items:center;justify-content:center;padding:18px 10px;border-radius:var(--r) 0 0 var(--r)}
.pname-txt{font-family:'Noto Sans SC',sans-serif;font-size:14px;font-weight:900;color:var(--purple);text-align:center;line-height:1.6;letter-spacing:.5px}
.icell{padding:16px 14px;border-right:1.5px solid rgba(0,0,0,.04);position:relative;display:flex;flex-direction:column;gap:7px}
.icell:last-child{border-right:none;border-radius:0 var(--r) var(--r) 0}
.icell-lbl{font-family:'Space Mono',monospace;font-size:8.5px;font-weight:700;letter-spacing:2px;text-transform:uppercase}
.icell.ins .icell-lbl{color:#2A7FBF}.icell.act .icell-lbl{color:#C49A00}.icell.imp .icell-lbl{color:#1A8C58}
.icell-txt{font-family:'Noto Sans SC',sans-serif;font-size:12.5px;color:var(--text-b);line-height:1.65}
.iarr{position:absolute;right:-15px;top:50%;transform:translateY(-50%);width:28px;height:28px;border-radius:50%;background:#fff;border:2px solid var(--purple-l);display:flex;align-items:center;justify-content:center;font-size:12px;color:var(--purple);font-weight:900;box-shadow:0 2px 8px rgba(124,110,245,.15);z-index:5}
.ibadge{display:inline-block;background:linear-gradient(90deg,var(--green-bg),#E8F4FF);border:1.5px solid var(--green-l);color:#1A8C58;font-size:11px;font-weight:800;font-family:'Space Mono',monospace;padding:3px 10px;border-radius:100px;margin-top:4px}
.ibadge.b{background:linear-gradient(90deg,#E8F4FF,var(--purple-bg));border-color:var(--blue-l);color:#2A7FBF}

/* ── S6 REPLICABLE ── */
#s6{background:var(--surface)}
.s6-title{font-weight:900;font-size:40px;color:var(--text-h);letter-spacing:-1px;margin-bottom:34px}
.s6-grid{display:grid;grid-template-columns:1fr 1.55fr;gap:46px;align-items:start}
.flowchart{display:flex;flex-direction:column}
.fn{display:flex;align-items:center;gap:14px;background:var(--purple-bg);border:2px solid var(--purple-l);border-radius:var(--rs);padding:13px 16px;transition:all .25s;cursor:default}
.fn:hover{background:var(--purple);border-color:var(--purple);box-shadow:var(--shh)}
.fn:hover .fn-ico{background:rgba(255,255,255,.2)}.fn:hover .fn-t{color:#fff}
.fn-ico{width:34px;height:34px;border-radius:8px;background:rgba(124,110,245,.15);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.fn-t{font-family:'Noto Sans SC',sans-serif;font-size:13px;font-weight:700;color:var(--text-b);line-height:1.5}
.farr{display:flex;justify-content:center;font-size:19px;color:var(--purple-l);padding:3px 0}
.dash{background:var(--surface);border:2px solid rgba(124,110,245,.14);border-radius:20px;overflow:hidden;box-shadow:var(--sh)}
.db-top{display:flex;align-items:center;gap:7px;padding:11px 16px;background:linear-gradient(90deg,var(--purple-bg),#fff);border-bottom:1.5px solid var(--border)}
.db-dot{width:11px;height:11px;border-radius:50%}
.db-ttl{font-family:'Space Mono',monospace;font-size:10px;color:var(--text-s);letter-spacing:2px;margin-left:6px;font-weight:700}
.db-body{padding:14px;display:flex;flex-direction:column;gap:12px}
.cbox{background:var(--bg);border:1.5px solid var(--border);border-radius:var(--rs);padding:13px}
.cttl{font-family:'Space Mono',monospace;font-size:9.5px;color:var(--text-s);letter-spacing:1.5px;text-transform:uppercase;margin-bottom:9px;font-weight:700}
/* line chart */
.lc{height:68px}
.lc svg{width:100%;height:100%;overflow:visible}
.lc-xl{display:flex;justify-content:space-between;font-family:'Space Mono',monospace;font-size:8.5px;color:var(--text-s);margin-top:4px}
/* bar chart */
.bc{display:flex;gap:8px;align-items:flex-end;height:68px}
.bcg{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end}
.bcc{width:100%;display:flex;align-items:flex-end;flex:1}
.bbar{width:100%;border-radius:5px 5px 0 0}
.bcl{font-family:'Space Mono',monospace;font-size:8px;color:var(--text-s);text-align:center;white-space:nowrap;line-height:1.4}
.bcarr{font-size:15px;color:var(--purple-l);display:flex;align-items:center;padding-bottom:18px}
/* table */
.dt{width:100%;border-collapse:collapse;font-size:11px}
.dt th{background:var(--purple-bg);color:var(--purple);font-family:'Space Mono',monospace;font-size:9px;letter-spacing:1px;font-weight:700;padding:7px 10px;text-align:left;border-bottom:2px solid var(--purple-l)}
.dt td{padding:7px 10px;border-bottom:1px solid rgba(124,110,245,.07);color:var(--text-b);font-weight:600}
.dbar{height:14px;border-radius:100px;display:flex;align-items:center;padding-left:8px;font-size:8.5px;font-family:'Space Mono',monospace;color:#fff;white-space:nowrap;font-weight:700}

/* ── S7 CROSS DEPT ── */
#s7{background:var(--purple-bg)}
.s7-title{font-weight:900;font-size:40px;color:var(--text-h);letter-spacing:-1px;margin-bottom:4px}
.s7-sub{font-family:'Noto Sans SC',sans-serif;font-size:16px;font-weight:700;color:var(--purple);margin-bottom:36px}
.cards{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.card{background:var(--surface);border-radius:20px;padding:26px 20px;position:relative;overflow:hidden;border:2px solid rgba(124,110,245,.09);box-shadow:var(--sh);transition:all .3s}
.card:hover{transform:translateY(-5px);box-shadow:var(--shh)}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;border-radius:20px 20px 0 0}
.card:nth-child(1)::before{background:linear-gradient(90deg,var(--purple),var(--blue))}
.card:nth-child(2)::before{background:linear-gradient(90deg,var(--yellow),var(--green))}
.card:nth-child(3)::before{background:linear-gradient(90deg,var(--green),var(--purple))}
.card-ico{width:50px;height:50px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;margin-bottom:14px}
.card:nth-child(1) .card-ico{background:var(--purple-bg)}
.card:nth-child(2) .card-ico{background:var(--yellow-bg)}
.card:nth-child(3) .card-ico{background:var(--green-bg)}
.card-num{font-family:'Space Mono',monospace;font-size:10px;color:var(--text-s);letter-spacing:3px;margin-bottom:6px;font-weight:700}
.card-title{font-family:'Noto Sans SC',sans-serif;font-size:17px;font-weight:900;color:var(--text-h);margin-bottom:12px;line-height:1.4}
.card-items{display:flex;flex-direction:column;gap:9px}
.ci{display:flex;align-items:flex-start;gap:8px;font-family:'Noto Sans SC',sans-serif;font-size:13px;color:var(--text-s);line-height:1.6}
.ci::before{content:'✦';color:var(--purple);font-size:9px;flex-shrink:0;margin-top:4px}

/* ── S8 GALLERY ── */
#s8{background:var(--surface)}
.s8-title{font-weight:900;font-size:40px;color:var(--text-h);text-align:center;letter-spacing:-1px;margin-bottom:32px}
.gg{display:grid;grid-template-columns:repeat(4,1fr);grid-template-rows:repeat(2,205px);gap:12px}
.gc{border-radius:var(--r);overflow:hidden;border:2px dashed var(--purple-l);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:9px;cursor:pointer;transition:all .25s;background:var(--purple-bg);position:relative}
.gc:nth-child(even){background:var(--pink-bg);border-color:var(--pink-l)}
.gc:nth-child(3n){background:var(--yellow-bg);border-color:var(--yellow-l)}
.gc:hover{transform:scale(1.02);box-shadow:var(--shh)}
.gc img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:var(--r)}
.gc-num{font-weight:900;font-size:34px;color:rgba(124,110,245,.13)}
.gc-ico{font-size:26px;opacity:.3}
.gc-lbl{font-family:'Space Mono',monospace;font-size:9px;color:var(--text-s);letter-spacing:2px;text-transform:uppercase;font-weight:700}

/* ── S9 THANK YOU ── */
#s9{background:linear-gradient(135deg,#F0EEFF 0%,#FFF0FA 50%,var(--green-bg) 100%);min-height:100vh;align-items:center;text-align:center}
.s9-title{font-weight:900;font-size:clamp(72px,11vw,140px);line-height:0.93;color:var(--text-h);letter-spacing:-4px}
.s9-title span{color:var(--purple)}
.s9-div{width:60px;height:4px;border-radius:100px;background:linear-gradient(90deg,var(--purple),var(--pink));margin:22px auto}
.s9-name{font-family:'Noto Sans SC',sans-serif;font-size:15px;font-weight:700;color:var(--text-s);letter-spacing:5px;text-transform:uppercase}

@media(max-width:900px){
  .s2-grid,.s6-grid{grid-template-columns:1fr;gap:30px}
  .cards{grid-template-columns:1fr;gap:14px}
  .gg{grid-template-columns:repeat(2,1fr)}
  .iai-cols,.prow{grid-template-columns:1fr}
  section,.flag-page{padding:72px 20px 48px}
  .roadmap{flex-direction:column;align-items:center;gap:18px}
  .rm-conn{width:3px;height:36px;margin:0}
  .rm-conn::after{content:'↓';top:auto;right:-12px;bottom:-12px}
}
</style>
</head>
<body>

<nav class="nav">
  <div class="nav-logo">✦ Portfolio</div>
  <div class="nav-dots" id="navDots"></div>
</nav>

<!-- S1 COVER -->
<section id="s1">
  <div class="blob b1"></div><div class="blob b2"></div><div class="blob b3"></div>
  <div class="inner" style="text-align:center">
    <div class="rv">
      <div class="s1-badge">✦ Overseas Content Growth · 2025</div>
      <div class="s1-title">Port<span>folio</span></div>
      <div class="s1-sub">海外内容增长作品集</div>
      <div class="s1-dots">
        <div class="s1-dot" style="background:var(--purple)"></div>
        <div class="s1-dot" style="background:var(--pink)"></div>
        <div class="s1-dot" style="background:var(--yellow)"></div>
        <div class="s1-dot" style="background:var(--green)"></div>
        <div class="s1-dot" style="background:var(--blue)"></div>
      </div>
    </div>
  </div>
</section>

<div class="wsep"><svg viewBox="0 0 1440 36" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,18 C240,36 480,0 720,18 C960,36 1200,0 1440,18 L1440,36 L0,36 Z" fill="#ffffff"/></svg></div>

<!-- S2 ABOUT -->
<section id="s2">
  <div class="inner">
    <div class="pill rv">✦ About Me</div>
    <div class="s2-grid">
      <div class="photo-wrap rv">
        <div class="photo-card">
          <div class="photo-icon">👤</div>
          <div class="photo-lbl">头像照片</div>
        </div>
        <div class="deco d1">⭐</div>
        <div class="deco d2">✦</div>
      </div>
      <div class="rv">
        <div class="s2-name">Jialin</div>
        <div class="s2-subtitle">3年+ · 海外内容增长</div>
        <div class="s2-tags">
          <div class="s2-tag"><div class="chk">✓</div>深度市场洞察</div>
          <div class="s2-tag"><div class="chk">✓</div>高效内容营销</div>
          <div class="s2-tag"><div class="chk">✓</div>闭环变现能力</div>
          <div class="s2-tag"><div class="chk">✓</div>全链路资源整合</div>
        </div>
      </div>
    </div>
  </div>
</section>

